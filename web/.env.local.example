# Absolute path to the repository root (directory that contains main.py and config.yaml).
# If you run `npm run dev` from web/, the default in code is the parent folder — often no env needed.
# REPO_ROOT=/absolute/path/to/agentic-production-house

# Python binary for the render subprocess — must be an interpreter where you ran:
#   pip install -r ../requirements.txt
# (System `python3` often lacks httpx/moviepy; prefer your venv.)
# PYTHON_PATH=/absolute/path/to/agentic-production-house/.venv/bin/python
